{% extends 'AntispamBundle::main.html.twig' %}

{% block title %}Add Account{% endblock %}
{% block page_title %}Add Account{% endblock %}

{% block body %}
    <form method="post" action="{{ path('antispam_account_add') }}">
        <div class="panel panel-default">
            <div class="panel-heading">General</div>
            <div class="panel-body">
                <div class="form-group">
                    <label>Account Name</label>
                    <input type="text" class="form-control" name="account[name]" placeholder="e.g. My Domain" required>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" class="form-control" name="account[email]" placeholder="user@example.com" required>
                </div>
                <div class="form-group">
                    <label>Connection Type</label>
                    <select class="form-control" name="account[connection_type]" id="connectionType" onchange="toggleFields()">
                        <option value="imap">IMAP</option>
                        <option value="ssh">SSH + Maildir</option>
                    </select>
                </div>
                <div class="form-group">
                    <label><input type="checkbox" name="account[delete_spam]" value="1"> Delete spam (instead of moving to SPAM folder)</label>
                </div>
            </div>
        </div>

        <div id="imapFields" class="panel panel-default">
            <div class="panel-heading">IMAP Settings</div>
            <div class="panel-body">
                <div class="form-group">
                    <label>IMAP Host</label>
                    <input type="text" class="form-control" name="account[imap_host]" placeholder="mail.example.com">
                </div>
                <div class="form-group">
                    <label>IMAP Port</label>
                    <input type="number" class="form-control" name="account[imap_port]" value="143">
                </div>
                <div class="form-group">
                    <label>Login</label>
                    <input type="text" class="form-control" name="account[imap_login]">
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" class="form-control" name="account[imap_password]">
                </div>
                <div class="form-group">
                    <label>IMAP Flags</label>
                    <input type="text" class="form-control" name="account[imap_flags]" value="/novalidate-cert/notls">
                </div>
            </div>
        </div>

        <div id="sshFields" class="panel panel-default" style="display:none;">
            <div class="panel-heading">SSH + Maildir Settings</div>
            <div class="panel-body">
                <div class="form-group">
                    <label>SSH Host</label>
                    <input type="text" class="form-control" name="account[ssh_host]" placeholder="hosting.example.com">
                </div>
                <div class="form-group">
                    <label>SSH Port</label>
                    <input type="number" class="form-control" name="account[ssh_port]" value="22">
                </div>
                <div class="form-group">
                    <label>SSH User</label>
                    <input type="text" class="form-control" name="account[ssh_user]">
                </div>
                <div class="form-group">
                    <label>SSH Key Path (on this server)</label>
                    <input type="text" class="form-control" name="account[ssh_key_path]" placeholder="/path/to/private_key">
                </div>
                <div class="form-group">
                    <label>Maildir Path (on hosting)</label>
                    <input type="text" class="form-control" name="account[maildir_path]" value="~/Maildir">
                </div>
                <div class="form-group">
                    <label>Agent Path (on hosting)</label>
                    <input type="text" class="form-control" name="account[agent_path]" value="~/antispam-agent">
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a href="{{ path('antispam_account_index') }}" class="btn btn-default">Cancel</a>
    </form>

    <script>
    function toggleFields() {
        var type = document.getElementById('connectionType').value;
        document.getElementById('imapFields').style.display = type === 'imap' ? 'block' : 'none';
        document.getElementById('sshFields').style.display = type === 'ssh' ? 'block' : 'none';
    }
    </script>
{% endblock %}
