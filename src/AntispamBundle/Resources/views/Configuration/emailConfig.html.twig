{% extends 'AntispamBundle::main.html.twig' %}
{% block title %}Legacy Account Configuration{% endblock %}
{% block page_title %}Legacy Account Configuration{% endblock %}

{% block body %}
    <div class="alert alert-info">
        <span class="glyphicon glyphicon-info-sign"></span>
        This is the legacy single-account configuration. For multi-account management, use
        <a href="{{ path('antispam_account_index') }}">Accounts</a>.
    </div>

    <div class="panel panel-default">
        <div class="panel-heading"><span class="glyphicon glyphicon-envelope"></span> IMAP Account Settings</div>
        <div class="panel-body">
            <form method="post" class="form-horizontal">
                <div class="form-group">
                    <label class="col-sm-3 control-label">Email</label>
                    <div class="col-sm-6">
                        <input type="email" class="form-control" name="config[email]" value="{{ config.email }}" placeholder="user@example.com">
                    </div>
                </div>
                <div class="form-group">
                    <label class="col-sm-3 control-label">Login</label>
                    <div class="col-sm-6">
                        <input type="text" class="form-control" name="config[login]" value="{{ config.login }}">
                    </div>
                </div>
                <div class="form-group">
                    <label class="col-sm-3 control-label">Password</label>
                    <div class="col-sm-6">
                        <input type="password" class="form-control" name="config[password]" value="{{ config.password }}">
                    </div>
                </div>
                <div class="form-group">
                    <label class="col-sm-3 control-label">IMAP Server</label>
                    <div class="col-sm-6">
                        <input type="text" class="form-control" name="config[imap]" value="{{ config.imap }}" placeholder="mail.example.com">
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-sm-offset-3 col-sm-6">
                        <button type="submit" class="btn btn-primary"><span class="glyphicon glyphicon-floppy-disk"></span> Save</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
