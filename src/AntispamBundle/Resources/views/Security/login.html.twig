<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Logowanie &middot; Pancernapanda antispam</title>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: linear-gradient(135deg, #0b2a52 0%, #1e4a8a 55%, #3b82f6 100%);
            color: #1f2a44;
            display: flex;
            min-height: 100vh;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .login-box {
            width: 100%;
            max-width: 400px;
            padding: 36px 32px;
            background: #ffffff;
            border: 1px solid #d5e1f2;
            border-radius: 10px;
            box-shadow: 0 14px 40px rgba(11, 42, 82, 0.25);
        }
        .pp-login-logo {
            display: flex;
            justify-content: center;
            margin-bottom: 14px;
        }
        .pp-login-logo svg {
            width: 64px;
            height: 64px;
            filter: drop-shadow(0 3px 6px rgba(11, 42, 82, 0.2));
        }
        .login-box h1 {
            margin: 0 0 6px;
            font-size: 22px;
            text-align: center;
            color: #0b2a52;
            font-weight: 700;
            letter-spacing: 0.3px;
        }
        .login-box .subtitle {
            margin: 0 0 24px;
            text-align: center;
            color: #5f7aa8;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }
        .form-group { margin-bottom: 16px; }
        .form-group label {
            display: block;
            margin-bottom: 6px;
            font-size: 14px;
            font-weight: 600;
            color: #0b2a52;
        }
        .form-control {
            display: block;
            width: 100%;
            padding: 9px 12px;
            font-size: 14px;
            line-height: 1.5;
            color: #1f2a44;
            background-color: #ffffff;
            border: 1px solid #c5d3ea;
            border-radius: 6px;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .form-control:focus {
            border-color: #1e4a8a;
            outline: 0;
            box-shadow: 0 0 0 3px rgba(30, 74, 138, 0.18);
        }
        .btn-primary {
            display: block;
            width: 100%;
            padding: 11px 16px;
            margin-top: 6px;
            font-size: 15px;
            font-weight: 600;
            color: #ffffff;
            background-color: #1e4a8a;
            border: 1px solid #0b2a52;
            border-radius: 6px;
            cursor: pointer;
            transition: background-color 0.15s, transform 0.05s;
        }
        .btn-primary:hover { background-color: #0b2a52; }
        .btn-primary:active { transform: translateY(1px); }
        .alert-danger {
            padding: 10px 14px;
            margin-bottom: 16px;
            color: #a94442;
            background-color: #fdecea;
            border: 1px solid #f5c6cb;
            border-radius: 6px;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <div class="pp-login-logo">
            <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Pancerna Panda">
                <circle cx="20" cy="21" r="14" fill="#ffffff" stroke="#0b2a52" stroke-width="1"/>
                <ellipse cx="10" cy="11" rx="5" ry="6" fill="#0b2a52"/>
                <ellipse cx="30" cy="11" rx="5" ry="6" fill="#0b2a52"/>
                <ellipse cx="13" cy="22" rx="4" ry="5" fill="#0b2a52"/>
                <ellipse cx="27" cy="22" rx="4" ry="5" fill="#0b2a52"/>
                <circle cx="13" cy="22" r="1.6" fill="#ffffff"/>
                <circle cx="27" cy="22" r="1.6" fill="#ffffff"/>
                <ellipse cx="20" cy="27" rx="2.2" ry="1.6" fill="#0b2a52"/>
                <path d="M16.5 30 Q20 33 23.5 30" stroke="#0b2a52" stroke-width="1.4" fill="none" stroke-linecap="round"/>
            </svg>
        </div>
        <h1>Pancernapanda</h1>
        <p class="subtitle">antispam</p>

        {% if error %}
            <div class="alert-danger">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form action="{{ path('login') }}" method="post">
            <div class="form-group">
                <label for="inputUsername">Username</label>
                <input type="text" id="inputUsername" name="_username" value="{{ last_username }}" class="form-control" autofocus required>
            </div>
            <div class="form-group">
                <label for="inputPassword">Password</label>
                <input type="password" id="inputPassword" name="_password" class="form-control" required>
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn-primary">Sign in</button>
        </form>
    </div>
</body>
</html>
