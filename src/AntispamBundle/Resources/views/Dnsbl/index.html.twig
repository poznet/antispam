{% extends 'AntispamBundle::main.html.twig' %}
{% block title %}DNSBL Providers{% endblock %}
{% block page_title %}DNSBL Providers{% endblock %}

{% block body %}
    <div class="panel panel-default">
        <div class="panel-heading"><span class="glyphicon glyphicon-plus"></span> Add custom DNSBL zone</div>
        <div class="panel-body">
            <form method="post" action="{{ path('antispam_dnsbl_add') }}" class="form-horizontal">
                <div class="form-group">
                    <label class="col-sm-2 control-label">Name</label>
                    <div class="col-sm-3"><input type="text" name="name" class="form-control" placeholder="Spamhaus ZEN" required></div>
                    <label class="col-sm-1 control-label">Zone</label>
                    <div class="col-sm-3"><input type="text" name="zone" class="form-control" placeholder="zen.spamhaus.org" required></div>
                    <label class="col-sm-1 control-label">Score</label>
                    <div class="col-sm-1"><input type="number" name="score" class="form-control" value="5" min="1" max="50"></div>
                    <div class="col-sm-1"><button type="submit" class="btn btn-primary">Add</button></div>
                </div>
            </form>
        </div>
    </div>

    <div class="panel panel-default">
        <div class="panel-heading"><span class="glyphicon glyphicon-th-list"></span> Configured providers</div>
        {% if providers|length > 0 %}
            <table class="table table-striped" style="margin-bottom:0;">
                <thead><tr><th>Name</th><th>Zone</th><th>Score</th><th>TTL</th><th>Hits</th><th>Status</th><th></th></tr></thead>
                <tbody>
                {% for p in providers %}
                <tr>
                    <td>{{ p.name }}</td>
                    <td><code>{{ p.zone }}</code></td>
                    <td>{{ p.score }}</td>
                    <td>{{ p.cacheTtl }}s</td>
                    <td>{{ p.hits }}</td>
                    <td>
                        {% if p.enabled %}
                            <span class="label label-success">enabled</span>
                        {% else %}
                            <span class="label label-default">disabled</span>
                        {% endif %}
                    </td>
                    <td class="text-right">
                        <a class="btn btn-xs btn-default" href="{{ path('antispam_dnsbl_toggle', {id: p.id}) }}">Toggle</a>
                        <a class="btn btn-xs btn-danger" href="{{ path('antispam_dnsbl_del', {id: p.id}) }}" onclick="return confirm('Delete {{ p.zone }}?')">Delete</a>
                    </td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="panel-body text-muted">No providers yet. Add one from the presets below.</div>
        {% endif %}
    </div>

    <div class="panel panel-default">
        <div class="panel-heading"><span class="glyphicon glyphicon-th"></span> Well-known presets</div>
        <table class="table table-striped" style="margin-bottom:0;">
            <thead><tr><th>Name</th><th>Zone</th><th>Suggested score</th><th></th></tr></thead>
            <tbody>
            {% for idx, preset in presets %}
                <tr>
                    <td>{{ preset.name }}</td>
                    <td><code>{{ preset.zone }}</code></td>
                    <td>{{ preset.score }}</td>
                    <td class="text-right"><a class="btn btn-xs btn-success" href="{{ path('antispam_dnsbl_add_preset', {idx: idx}) }}">Add</a></td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="panel panel-default">
        <div class="panel-heading"><span class="glyphicon glyphicon-search"></span> Test an IP</div>
        <div class="panel-body">
            <form method="get" action="{{ path('antispam_dnsbl_test') }}" class="form-inline">
                <input type="text" name="ip" class="form-control" placeholder="1.2.3.4" style="min-width:220px;">
                <button type="submit" class="btn btn-default">Check</button>
            </form>
        </div>
    </div>
{% endblock %}
