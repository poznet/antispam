{% extends 'AntispamBundle::main.html.twig' %}
{% block title %}Spambox{% endblock %}
{% block page_title %}Spambox{% endblock %}

{% block body %}
    {% if messages|length > 0 %}
    <div class="row">
        <div class="col-sm-4">
            <div class="list-group">
            {% for msg in messages %}
                <a href="#" class="list-group-item spamboxmsgheader" rel="{{ msg.id }}" {% if loop.first %}style="background:#f0f0f0;"{% endif %}>
                    <small class="text-muted pull-right">{{ msg.date | date("d-m-Y") }}</small>
                    <strong class="list-group-item-heading" style="font-size:12px;">{{ msg.from }}</strong>
                    <p class="list-group-item-text" style="font-size:11px; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ msg.subject[:60] }}</p>
                </a>
            {% endfor %}
            </div>
        </div>
        <div class="col-sm-8">
            <div class="panel panel-default">
                <div class="panel-body spamboxmsgcontent">
                    {{ messages.0.content | raw }}
                </div>
            </div>
        </div>
    </div>
    {% else %}
    <div class="empty-state">
        <span class="glyphicon glyphicon-inbox"></span>
        <p>Spambox is empty</p>
        <p class="text-muted">No spam messages found</p>
    </div>
    {% endif %}
{% endblock %}
