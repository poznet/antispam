{% extends 'AntispamBundle::main.html.twig' %}
{% block title %}E-mail Blacklist{% endblock %}
{% block page_title %}E-mail Blacklist{% endblock %}

{% block body %}
    <div class="add-form">
        <form method="post" action="{{ path('antispam_emailblacklist_add') }}" class="form-inline">
            <input type="text" class="form-control" name="email" placeholder="spammer@example.com or *@*.ru or regex" required style="min-width:280px;">
            <select name="pattern_type" class="form-control">
                <option value="exact">Exact</option>
                <option value="wildcard">Wildcard</option>
                <option value="regex">Regex</option>
            </select>
            <input type="number" class="form-control" name="score" value="10" min="1" max="50" title="Spam score added on hit" style="width:90px;">
            <button type="submit" class="btn btn-danger"><span class="glyphicon glyphicon-plus"></span> Add</button>
        </form>
    </div>

    {% if list|length > 0 %}
    <ul class="list-group">
        {% for l in list %}
        <li class="list-group-item">
            <a href="{{ path('antispam_emailblacklist_del',{'id':l.id}) }}" class="btn btn-danger btn-xs list-actions" onclick="return confirm('Delete this email from blacklist?')">
                <span class="glyphicon glyphicon-remove"></span> Delete
            </a>
            <span class="badge badge-counter">{{ l.counter }} hits</span>
            <span class="label label-default">{{ l.patternType }}</span>
            <span class="label label-warning">score {{ l.score }}</span>
            <span class="glyphicon glyphicon-envelope"></span> {{ l.blacklistemail }}
        </li>
        {% endfor %}
    </ul>
    {% else %}
    <div class="empty-state">
        <span class="glyphicon glyphicon-ban-circle"></span>
        <p>No emails in blacklist yet</p>
        <p class="text-muted">Supports exact, wildcard and regex patterns</p>
    </div>
    {% endif %}
{% endblock %}
