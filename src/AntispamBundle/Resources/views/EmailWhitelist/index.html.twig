{% extends 'AntispamBundle::main.html.twig' %}
{% block title %}E-mail Whitelist{% endblock %}
{% block page_title %}E-mail Whitelist{% endblock %}

{% block body %}
    <div class="add-form">
        <form method="post" action="{{ path('antispam_emailwhitelist_add') }}" class="form-inline">
            <input type="text" class="form-control" name="email" placeholder="friend@example.com or *@trusted.example" required style="min-width:280px;">
            <select name="pattern_type" class="form-control">
                <option value="exact">Exact</option>
                <option value="wildcard">Wildcard</option>
                <option value="regex">Regex</option>
            </select>
            <button type="submit" class="btn btn-success"><span class="glyphicon glyphicon-plus"></span> Add</button>
        </form>
    </div>

    {% if list|length > 0 %}
    <ul class="list-group">
        {% for l in list %}
        <li class="list-group-item">
            <a href="{{ path('antispam_emailwhitelist_del',{'id':l.id}) }}" class="btn btn-danger btn-xs list-actions" onclick="return confirm('Remove this email from whitelist?')">
                <span class="glyphicon glyphicon-remove"></span> Delete
            </a>
            <span class="badge badge-counter">{{ l.counter }} hits</span>
            <span class="label label-default">{{ l.patternType }}</span>
            <span class="glyphicon glyphicon-envelope"></span> {{ l.whitelistemail }}
        </li>
        {% endfor %}
    </ul>
    {% else %}
    <div class="empty-state">
        <span class="glyphicon glyphicon-ok-circle"></span>
        <p>No emails in whitelist yet</p>
        <p class="text-muted">Supports exact, wildcard and regex patterns</p>
    </div>
    {% endif %}
{% endblock %}
