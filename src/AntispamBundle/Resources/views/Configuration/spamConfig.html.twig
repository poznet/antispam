{% extends 'AntispamBundle::main.html.twig' %}
{% block title %}Spam Filter Settings{% endblock %}
{% block page_title %}Spam Filter Settings{% endblock %}

{% block body %}
    <div class="panel panel-default">
        <div class="panel-heading"><span class="glyphicon glyphicon-wrench"></span> Maintenance</div>
        <div class="panel-body">
            <a href="{{ path('antispam_spam_unchekall') }}" class="btn btn-warning" onclick="return confirm('Reset all checked flags? This will re-process all messages on next scan.')">
                <span class="glyphicon glyphicon-refresh"></span> Reset All Checked Flags
            </a>
            <a href="{{ path('antispam_spam_resetcounters') }}" class="btn btn-warning" onclick="return confirm('Reset all rule counters to zero?')">
                <span class="glyphicon glyphicon-stats"></span> Reset All Counters
            </a>
        </div>
    </div>

    <div class="panel panel-default">
        <div class="panel-heading"><span class="glyphicon glyphicon-cog"></span> Spam Handling</div>
        <div class="panel-body">
            <form method="post">
                <input type="hidden" name="config['test']" value="aaa">
                <div class="row" style="padding: 15px 0;">
                    <div class="col-xs-9">
                        <strong>Delete spam messages permanently</strong>
                        <p class="text-muted" style="margin:0;">When disabled, spam messages are moved to the SPAM folder instead of being deleted</p>
                    </div>
                    <div class="col-xs-3 text-right">
                        <div class="onoffswitch">
                            <input type="checkbox" name="config[delete]" value="true" class="onoffswitch-checkbox" id="myonoffswitch" {% if config.delete==true %}checked{% endif %}>
                            <label class="onoffswitch-label" for="myonoffswitch">
                                <span class="onoffswitch-inner"></span>
                                <span class="onoffswitch-switch"></span>
                            </label>
                        </div>
                    </div>
                </div>
                <hr>
                <button type="submit" class="btn btn-primary"><span class="glyphicon glyphicon-floppy-disk"></span> Save</button>
            </form>
        </div>
    </div>
{% endblock %}
