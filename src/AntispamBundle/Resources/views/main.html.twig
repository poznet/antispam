<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Antispam{% endblock %} &middot; Pancernapanda antispam</title>

    {% javascripts
    'assets/jquery/dist/jquery.min.js'
    'assets/bootstrap/dist/js/bootstrap.min.js'

    %}
    <script src="{{ asset_url }}"></script>
    {% endjavascripts %}

    {% stylesheets
    'assets/bootstrap/dist/css/bootstrap.min.css'
    'assets/bootstrap/dist/css/bootstrap-theme.min.css'
    '@AntispamBundle/Resources/private/css/*.css'
    filter='cssrewrite' %}
    <link rel="stylesheet" href="{{ asset_url }}" />
    {% endstylesheets %}
</head>
<body>
<nav class="navbar navbar-inverse navbar-fixed-top">
    <div class="container">
        <div class="navbar-header">
            <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#main-navbar" aria-expanded="false">
                <span class="sr-only">Toggle navigation</span>
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
            </button>
            <a class="navbar-brand brand-pp" href="{{ path('antispam_index') }}">
                <span class="pp-logo" aria-hidden="true">
                    <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" width="28" height="28" role="img" aria-label="Pancerna Panda">
                        <circle cx="20" cy="21" r="14" fill="#ffffff"/>
                        <ellipse cx="10" cy="11" rx="5" ry="6" fill="#0b2a52"/>
                        <ellipse cx="30" cy="11" rx="5" ry="6" fill="#0b2a52"/>
                        <ellipse cx="13" cy="22" rx="4" ry="5" fill="#0b2a52"/>
                        <ellipse cx="27" cy="22" rx="4" ry="5" fill="#0b2a52"/>
                        <circle cx="13" cy="22" r="1.6" fill="#ffffff"/>
                        <circle cx="27" cy="22" r="1.6" fill="#ffffff"/>
                        <ellipse cx="20" cy="27" rx="2.2" ry="1.6" fill="#0b2a52"/>
                        <path d="M16.5 30 Q20 33 23.5 30" stroke="#0b2a52" stroke-width="1.4" fill="none" stroke-linecap="round"/>
                    </svg>
                </span>
                <span class="pp-brand-text">
                    <strong>Pancernapanda</strong><span class="pp-brand-sub">antispam</span>
                </span>
            </a>
        </div>

        <div class="collapse navbar-collapse" id="main-navbar">
            <ul class="nav navbar-nav">
                <li><a href="{{ path('antispam_index') }}"><span class="glyphicon glyphicon-dashboard"></span> Dashboard</a></li>
                <li><a href="{{ path('antispam_account_index') }}"><span class="glyphicon glyphicon-cloud"></span> Accounts</a></li>
                <li class="dropdown">
                    <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                        <span class="glyphicon glyphicon-trash"></span> Mailboxes <span class="caret"></span>
                    </a>
                    <ul class="dropdown-menu">
                        <li><a href="{{ path('antispam_spambox_index') }}"><span class="glyphicon glyphicon-trash"></span> Spambox</a></li>
                        <li><a href="{{ path('antispam_spambox_quarantine') }}"><span class="glyphicon glyphicon-warning-sign"></span> Quarantine</a></li>
                        <li><a href="{{ path('antispam_spambox_scorelog') }}"><span class="glyphicon glyphicon-list-alt"></span> Score Log</a></li>
                    </ul>
                </li>
                <li class="dropdown">
                    <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                        <span class="glyphicon glyphicon-ok-circle"></span> Whitelists <span class="caret"></span>
                    </a>
                    <ul class="dropdown-menu">
                        <li><a href="{{ path('antispam_whitelist_index') }}"><span class="glyphicon glyphicon-globe"></span> Domain Whitelist</a></li>
                        <li><a href="{{ path('antispam_emailwhitelist_index') }}"><span class="glyphicon glyphicon-envelope"></span> E-mail Whitelist</a></li>
                    </ul>
                </li>
                <li class="dropdown">
                    <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                        <span class="glyphicon glyphicon-ban-circle"></span> Blacklists <span class="caret"></span>
                    </a>
                    <ul class="dropdown-menu">
                        <li><a href="{{ path('antispam_blacklist_index') }}"><span class="glyphicon glyphicon-globe"></span> Domain Blacklist</a></li>
                        <li><a href="{{ path('antispam_emailblacklist_index') }}"><span class="glyphicon glyphicon-envelope"></span> E-mail Blacklist</a></li>
                        <li><a href="{{ path('antispam_dnsbl_index') }}"><span class="glyphicon glyphicon-globe"></span> DNSBL Providers</a></li>
                        <li role="separator" class="divider"></li>
                        <li><a href="{{ path('antispam_bulk_index') }}"><span class="glyphicon glyphicon-transfer"></span> Bulk Import/Export</a></li>
                    </ul>
                </li>
                <li class="dropdown">
                    <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                        <span class="glyphicon glyphicon-cog"></span> Settings <span class="caret"></span>
                    </a>
                    <ul class="dropdown-menu">
                        <li><a href="{{ path('antispam_account_config') }}">Legacy Account Config</a></li>
                        <li><a href="{{ path('antispam_spam_config') }}">Spam Filter Settings</a></li>
                    </ul>
                </li>
            </ul>
            {% if app.user %}
                <ul class="nav navbar-nav navbar-right">
                    <li class="navbar-text" style="margin-right: 10px;">
                        <span class="glyphicon glyphicon-user"></span> {{ app.user.username }}
                    </li>
                    <li><a href="{{ path('logout') }}"><span class="glyphicon glyphicon-log-out"></span> Logout</a></li>
                </ul>
            {% endif %}
        </div>
    </div>
</nav>

<div class="container" style="padding-top: 70px;">
    {% for type, messages in app.session.flashbag.all() %}
        {% for message in messages %}
            <div class="alert alert-{{ type }} alert-dismissible" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="page-header">
        <h2>{% block page_title %}{% endblock %}</h2>
    </div>

    {% block body %}{% endblock %}
</div>

<footer class="footer">
    <div class="container">
        <p><strong>Pancernapanda antispam</strong> &mdash; pancerna ochrona Twojej skrzynki przed spamem</p>
    </div>
</footer>
</body>
</html>
