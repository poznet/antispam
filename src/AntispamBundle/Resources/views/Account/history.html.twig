{% extends 'AntispamBundle::main.html.twig' %}

{% block title %}Scan History: {{ account.name }}{% endblock %}
{% block page_title %}Scan History: {{ account.name }}{% endblock %}

{% block body %}
    <div class="row" style="margin-bottom:15px;">
        <div class="col-xs-12">
            <a href="{{ path('antispam_account_index') }}" class="btn btn-default">Back to Accounts</a>
            <a href="{{ path('antispam_account_scan', {id: account.id}) }}" class="btn btn-primary">Run New Scan</a>
        </div>
    </div>

    {% if logs|length > 0 %}
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Status</th>
                <th>Duration</th>
                <th>Total</th>
                <th>Checked</th>
                <th>Skipped</th>
                <th>Whitelisted</th>
                <th>Blacklisted</th>
                <th>Spam</th>
            </tr>
        </thead>
        <tbody>
        {% for log in logs %}
            <tr class="{{ log.success ? '' : 'danger' }}">
                <td>{{ log.scannedAt|date('Y-m-d H:i:s') }}</td>
                <td><span class="label label-{{ log.scanType == 'ssh' ? 'info' : 'default' }}">{{ log.scanType|upper }}</span></td>
                <td>
                    {% if log.success %}
                        <span class="label label-success">OK</span>
                    {% else %}
                        <span class="label label-danger">FAILED</span>
                    {% endif %}
                </td>
                <td>
                    {% if log.durationMs is not null %}
                        {{ (log.durationMs / 1000)|number_format(1) }}s
                    {% else %}
                        --
                    {% endif %}
                </td>
                {% if log.success %}
                    <td>{{ log.totalMessages }}</td>
                    <td>{{ log.checked }}</td>
                    <td>{{ log.skipped }}</td>
                    <td>{{ log.whitelisted }}</td>
                    <td>{{ log.blacklisted }}</td>
                    <td>{{ log.movedToSpam }}</td>
                {% else %}
                    <td colspan="6" class="text-danger">{{ log.errorMessage }}</td>
                {% endif %}
            </tr>
        {% endfor %}
        </tbody>
    </table>

    {% if logs|length >= 50 %}
        <p class="text-muted text-center">Showing last 50 entries</p>
    {% endif %}

    {% else %}
        <div class="empty-state">
            <span class="glyphicon glyphicon-time"></span>
            <p>No scan history yet</p>
            <a href="{{ path('antispam_account_scan', {id: account.id}) }}" class="btn btn-primary">Run First Scan</a>
        </div>
    {% endif %}
{% endblock %}
