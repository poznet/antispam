{% extends 'AntispamBundle::main.html.twig' %}
{% block title %}DNSBL Lookup{% endblock %}
{% block page_title %}DNSBL Lookup{% endblock %}

{% block body %}
    <form method="get" action="{{ path('antispam_dnsbl_test') }}" class="form-inline" style="margin-bottom:15px;">
        <input type="text" name="ip" class="form-control" value="{{ ip }}" placeholder="1.2.3.4" style="min-width:220px;">
        <button type="submit" class="btn btn-primary">Check</button>
        <a href="{{ path('antispam_dnsbl_index') }}" class="btn btn-default">Back</a>
    </form>

    {% if ip %}
        <h4>Results for <code>{{ ip }}</code></h4>
        {% if results|length > 0 %}
        <table class="table table-striped">
            <thead><tr><th>Provider</th><th>Zone</th><th>Listed</th><th>Response</th></tr></thead>
            <tbody>
            {% for r in results %}
                <tr class="{{ r.listed ? 'danger' : '' }}">
                    <td>{{ r.provider.name }}</td>
                    <td><code>{{ r.provider.zone }}</code></td>
                    <td>{{ r.listed ? 'YES' : 'no' }}</td>
                    <td><code>{{ r.response|default('-') }}</code></td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% else %}
            <p class="text-muted">No providers configured or invalid IP.</p>
        {% endif %}
    {% endif %}
{% endblock %}
