# Copy to .env (or paste into Coolify's Environment Variables UI) and adjust.

# Symfony
APP_SECRET=please-change-me-to-a-random-32char-string

# Database (used by both the app and the db service)
DATABASE_NAME=antispam
DATABASE_USER=antispam
DATABASE_PASSWORD=antispam
DATABASE_ROOT_PASSWORD=rootpassword

# Mailer (optional - leave empty to disable outbound mail)
MAILER_TRANSPORT=smtp
MAILER_HOST=127.0.0.1
MAILER_USER=
MAILER_PASSWORD=

# Set to "false" if you want to manage the schema manually instead of running
# doctrine:schema:update on each boot.
RUN_MIGRATIONS=true
