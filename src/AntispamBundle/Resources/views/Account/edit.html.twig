{% extends 'AntispamBundle::main.html.twig' %}

{% block title %}Edit Account: {{ account.name }}{% endblock %}
{% block page_title %}Edit Account: {{ account.name }}{% endblock %}

{% block body %}
    {% if errors is defined and errors|length > 0 %}
        <div class="alert alert-danger">
            <strong>Validation errors:</strong>
            <ul>
            {% for error in errors %}
                <li>{{ error.message }}</li>
            {% endfor %}
            </ul>
        </div>
    {% endif %}

    <form method="post" action="{{ path('antispam_account_edit', {id: account.id}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('account_form') }}">

        <div class="panel panel-default">
            <div class="panel-heading">General</div>
            <div class="panel-body">
                <div class="form-group">
                    <label>Account Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" name="account[name]" value="{{ account.name }}" required>
                </div>
                <div class="form-group">
                    <label>Email <span class="text-danger">*</span></label>
                    <input type="email" class="form-control" name="account[email]" value="{{ account.email }}" required>
                </div>
                <div class="form-group">
                    <label>Connection Type</label>
                    <select class="form-control" name="account[connection_type]" id="connectionType" onchange="toggleFields()">
                        <option value="imap" {% if account.connectionType == 'imap' %}selected{% endif %}>IMAP</option>
                        <option value="ssh" {% if account.connectionType == 'ssh' %}selected{% endif %}>SSH + Maildir</option>
                    </select>
                </div>
                <div class="form-group">
                    <label><input type="checkbox" name="account[delete_spam]" value="1" {% if account.deleteSpam %}checked{% endif %}> Delete spam (instead of moving to SPAM folder)</label>
                </div>
            </div>
        </div>

        <div id="imapFields" class="panel panel-default" {% if account.connectionType == 'ssh' %}style="display:none;"{% endif %}>
            <div class="panel-heading">IMAP Settings</div>
            <div class="panel-body">
                <div class="form-group">
                    <label>IMAP Host</label>
                    <input type="text" class="form-control" name="account[imap_host]" value="{{ account.imapHost }}">
                </div>
                <div class="form-group">
                    <label>IMAP Port</label>
                    <input type="number" class="form-control" name="account[imap_port]" value="{{ account.imapPort }}" min="1" max="65535">
                </div>
                <div class="form-group">
                    <label>Login</label>
                    <input type="text" class="form-control" name="account[imap_login]" value="{{ account.imapLogin }}">
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" class="form-control" name="account[imap_password]" value="{{ account.imapPassword }}">
                </div>
                <div class="form-group">
                    <label>IMAP Flags</label>
                    <input type="text" class="form-control" name="account[imap_flags]" value="{{ account.imapFlags }}">
                </div>
            </div>
        </div>

        <div id="sshFields" class="panel panel-default" {% if account.connectionType != 'ssh' %}style="display:none;"{% endif %}>
            <div class="panel-heading">SSH + Maildir Settings</div>
            <div class="panel-body">
                <div class="form-group">
                    <label>SSH Host</label>
                    <input type="text" class="form-control" name="account[ssh_host]" value="{{ account.sshHost }}">
                </div>
                <div class="form-group">
                    <label>SSH Port</label>
                    <input type="number" class="form-control" name="account[ssh_port]" value="{{ account.sshPort }}" min="1" max="65535">
                </div>
                <div class="form-group">
                    <label>SSH User</label>
                    <input type="text" class="form-control" name="account[ssh_user]" value="{{ account.sshUser }}">
                </div>
                <div class="form-group">
                    <label>SSH Key Path (on this server)</label>
                    <input type="text" class="form-control" name="account[ssh_key_path]" value="{{ account.sshKeyPath }}">
                    <p class="help-block">Path to a key file on the Antispam server, <strong>or</strong> paste the key below.</p>
                </div>
                <div class="form-group">
                    <label>SSH Private Key (paste PEM content)</label>
                    <textarea class="form-control" name="account[ssh_key_private]" rows="6" placeholder="Leave empty to keep existing key" style="font-family:monospace;font-size:12px;">{% if account.sshKeyPrivate %}(encrypted key stored){% endif %}</textarea>
                    <p class="help-block">The key will be encrypted before storage. Leave empty to keep the current key.</p>
                </div>
                <div class="form-group">
                    <label>SSH Key Passphrase (optional)</label>
                    <input type="password" class="form-control" name="account[ssh_key_passphrase]" placeholder="Leave empty if key has no passphrase">
                </div>
                <div class="form-group">
                    <label>Maildir Path (on hosting)</label>
                    <input type="text" class="form-control" name="account[maildir_path]" value="{{ account.maildirPath }}">
                </div>
                <div class="form-group">
                    <label>Agent Path (on hosting)</label>
                    <input type="text" class="form-control" name="account[agent_path]" value="{{ account.agentPath }}">
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a href="{{ path('antispam_account_index') }}" class="btn btn-default">Cancel</a>
    </form>

    <script>
    function toggleFields() {
        var type = document.getElementById('connectionType').value;
        document.getElementById('imapFields').style.display = type === 'imap' ? 'block' : 'none';
        document.getElementById('sshFields').style.display = type === 'ssh' ? 'block' : 'none';
    }
    </script>
{% endblock %}
