{% extends 'AntispamBundle::main.html.twig' %}
{% block title %}Spam Filter Settings{% endblock %}
{% block page_title %}Spam Filter Settings{% endblock %}

{% block body %}
    <form method="post">
    <div class="panel panel-default">
        <div class="panel-heading"><span class="glyphicon glyphicon-stats"></span> Spam Scoring</div>
        <div class="panel-body">
            <div class="checkbox"><label>
                <input type="checkbox" name="config[scoring_enabled]" {% if config.scoring_enabled %}checked{% endif %}>
                <strong>Enable scoring pipeline</strong> — combine blacklist / header / DNSBL signals before deciding.
            </label></div>
            <div class="checkbox"><label>
                <input type="checkbox" name="config[header_check_enabled]" {% if config.header_check_enabled %}checked{% endif %}>
                Run header heuristics (SPF / DKIM / DMARC, suspicious subject, missing Message-ID, ...)
            </label></div>
            <div class="checkbox"><label>
                <input type="checkbox" name="config[dnsbl_enabled]" {% if config.dnsbl_enabled %}checked{% endif %}>
                Check sender IP against configured DNSBL providers
            </label></div>
            <div class="checkbox"><label>
                <input type="checkbox" name="config[log_enabled]" {% if config.log_enabled %}checked{% endif %}>
                Persist per-message score log (recommended)
            </label></div>

            <div class="row" style="margin-top:10px;">
                <div class="col-sm-6">
                    <label>Quarantine threshold</label>
                    <input type="number" name="config[quarantine_threshold]" class="form-control" value="{{ config.quarantine_threshold }}" min="0" max="100">
                    <small class="text-muted">Score ≥ this value → move to QUARANTINE folder.</small>
                </div>
                <div class="col-sm-6">
                    <label>Spam threshold</label>
                    <input type="number" name="config[spam_threshold]" class="form-control" value="{{ config.spam_threshold }}" min="1" max="200">
                    <small class="text-muted">Score ≥ this value → treat as spam.</small>
                </div>
            </div>
        </div>
    </div>

    <div class="panel panel-default">
        <div class="panel-heading"><span class="glyphicon glyphicon-cog"></span> Spam Handling</div>
        <div class="panel-body">
            <div class="row" style="padding: 15px 0;">
                <div class="col-xs-9">
                    <strong>Delete spam messages permanently</strong>
                    <p class="text-muted" style="margin:0;">When disabled, spam messages are moved to the SPAM folder instead of being deleted</p>
                </div>
                <div class="col-xs-3 text-right">
                    <input type="checkbox" name="config[delete]" {% if config.delete==true %}checked{% endif %}>
                </div>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary"><span class="glyphicon glyphicon-floppy-disk"></span> Save</button>
    </form>

    <div class="panel panel-default" style="margin-top:20px;">
        <div class="panel-heading"><span class="glyphicon glyphicon-wrench"></span> Maintenance</div>
        <div class="panel-body">
            <a href="{{ path('antispam_spam_unchekall') }}" class="btn btn-warning" onclick="return confirm('Reset all checked flags? This will re-process all messages on next scan.')">
                <span class="glyphicon glyphicon-refresh"></span> Reset All Checked Flags
            </a>
            <a href="{{ path('antispam_spam_resetcounters') }}" class="btn btn-warning" onclick="return confirm('Reset all rule counters to zero?')">
                <span class="glyphicon glyphicon-stats"></span> Reset All Counters
            </a>
        </div>
    </div>
{% endblock %}
